<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.lmdlspfinal.bookstore_frontend.controllers.HomeController"
            style="-fx-background-color: #f5f0ff;">

    <!-- TOP NAV -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #6a0dad; -fx-padding: 15;">
            <Text text="📚 Javatheneum" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search books..." prefWidth="200"/>
            <Button text="Search" onAction="#handleSearch"
                    style="-fx-background-color: white; -fx-text-fill: #6a0dad;"/>
            <Button text="❤ Wishlist" onAction="#handleWishlist"
                    style="-fx-background-color: white; -fx-text-fill: #6a0dad;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- BOOK GRID -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f5f0ff;">
            <VBox spacing="10" style="-fx-padding: 20;">
                <Label fx:id="statusLabel" style="-fx-font-size: 14; -fx-text-fill: #6a0dad;"/>
                <FlowPane fx:id="bookGrid" hgap="15" vgap="15"/>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>